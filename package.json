{
  "name": "football-predictions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx src/db/seed.ts",
    "seed:neon": "npx tsx src/db/seed-neon.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "scrape": "npx tsx src/scripts/scrape.ts",
    "scrape:standings": "npx tsx src/scripts/scrape.ts --standings",
    "scrape:ligue1": "npx tsx src/scripts/scrape.ts --league ligue1",
    "scrape:premier": "npx tsx src/scripts/scrape.ts --league premier-league",
    "scrape:laliga": "npx tsx src/scripts/scrape.ts --league la-liga"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "axios": "^1.18.1",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.0"
}
